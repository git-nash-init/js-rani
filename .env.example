# Copy this file to .env.local and fill in your values.
# ─── Web3Forms ────────────────────────────────────────────────
# Get a free key at https://web3forms.com
NEXT_PUBLIC_WEB3FORMS_KEY=

# ─── PayU Payment Gateway ─────────────────────────────────────
PAYU_KEY=
PAYU_SALT=
PAYU_MODE=TEST

# ─── Base URL ─────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://www.jsranifoods.com

# ─── SMTP (order confirmation emails via Hostinger) ────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=marketing@jagadambastore.com
SMTP_PASS=
ADMIN_EMAIL=marketing@jagadambastore.com
